# For more information, please see the README.md

# --- suno-api 원본 (Suno.ai 음악 생성 브라우저 자동화) ---
SUNO_COOKIE=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true
BROWSER_EXECUTABLE_PATH= # 선택 — 특정 Chromium/Playwright 바이너리 경로를 강제할 때만 설정

# --- DGM 파이프라인 확장분 ---
# Claude API 직접 호출용 (generate-prompts/suggest-topics/trend-insight 라우트).
# 주의: VPS의 orchestrator 자체는 이 키가 아니라 Claude Pro OAuth로 실행해야 한다
# (ANTHROPIC_API_KEY가 설정되어 있으면 OAuth보다 우선되어 토큰당 과금됨).
ANTHROPIC_API_KEY=
# Evolink 프록시 API 키 — Midjourney(/api/midjourney), nano-banana(/api/nano-banana),
# Kling(/api/kling-i2v), /api/upload-evolink 라우트가 공용으로 사용
EVOLINK_KEY=
# Gemini API 키 — researcher의 인기영상 분석(scripts/gemini_analyzer.py, jazz_guide_analyzer.py)
GEMINI_API_KEY=
# Unsplash API 키 — /api/unsplash-search (배경 이미지 후보 검색)
UNSPLASH_ACCESS_KEY=

# 배포 서버 루트 디렉토리 (src/lib/serverPaths.ts 참고).
# Linux 계열(VPS/RunPod)에서만 필요 — 비워두면 /home/dgm/suno-api 기본값 사용.
# Windows 네이티브에서는 사용되지 않음.
PROJECT_DIR=
